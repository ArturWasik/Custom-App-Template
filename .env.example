# Environment variables for ASP.NET Core
# Double underscore (__) is the section separator (maps to : in appsettings.json)

# OpenAI API key (required)
OpenAI__ApiKey=your_openai_api_key_here

# API key for bearer token auth (optional — if empty, auth is disabled)
Auth__ApiKey=your_api_key_here

# Server port (optional, defaults to 3000)
Server__Port=3000
